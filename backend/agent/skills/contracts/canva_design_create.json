{
  "name": "canva.design_create",
  "version": "1.0.0",
  "summary": "Create a Canva design",
  "provider": { "service": "canva", "auth": "oauth", "scopes": ["design:content:write"] },
  "runtime_tools": ["canva_design_create"],
  "autofill": {
    "sources": [],
    "rules": ["design_type must be supplied as Canva-compatible object"]
  },
  "input_schema": {
    "type": "object",
    "required": ["design_type"],
    "properties": {
      "title": { "type": ["string", "null"] },
      "design_type": { "type": "object" }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["status"],
    "properties": {
      "status": { "type": "string", "enum": ["success", "needs_input", "error"] },
      "result": { "type": ["object", "null"] },
      "needs_input": { "type": ["object", "null"] },
      "error": { "type": ["object", "null"] }
    },
    "additionalProperties": false
  },
  "examples": [
    { "name": "poster", "input": { "title": "런칭 포스터", "design_type": { "type": "poster", "name": "Poster" } } }
  ]
}
