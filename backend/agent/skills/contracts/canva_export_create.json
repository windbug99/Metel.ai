{
  "name": "canva.export_create",
  "version": "1.0.0",
  "summary": "Create a Canva export job",
  "provider": { "service": "canva", "auth": "oauth", "scopes": ["design:content:read"] },
  "runtime_tools": ["canva_export_create", "canva_design_list"],
  "autofill": {
    "sources": [],
    "rules": ["if design_id is missing, resolve from design_title via canva_design_list"]
  },
  "input_schema": {
    "type": "object",
    "required": ["format"],
    "properties": {
      "design_id": { "type": ["string", "null"] },
      "design_title": { "type": ["string", "null"] },
      "format": { "type": "object" }
    },
    "additionalProperties": false
  },
  "output_schema": {
    "type": "object",
    "required": ["status"],
    "properties": {
      "status": { "type": "string", "enum": ["success", "needs_input", "error"] },
      "result": { "type": ["object", "null"] },
      "needs_input": { "type": ["object", "null"] },
      "error": { "type": ["object", "null"] }
    },
    "additionalProperties": false
  },
  "examples": [
    { "name": "pdf_by_title", "input": { "design_title": "런칭 포스터", "format": { "type": "pdf" } } }
  ]
}
